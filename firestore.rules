// Firestore Security Rules for Sa2e7 App
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════

    // Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Get the current user's UID
    function userId() {
      return request.auth.uid;
    }

    // Check if document belongs to current user
    function isOwner(ownerId) {
      return isAuth() && userId() == ownerId;
    }

    // Check if the request is from the owner of the business
    function isBusinessOwner(businessOwnerId) {
      return isAuth() && userId() == businessOwnerId;
    }

    // ═══════════════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════════

    // /Users/{userId} - User profiles and preferences
    match /Users/{userId} {
      // Users can only read and write their own document
      allow read, write: if isOwner(userId);

      // New user registration: allow creating own document
      allow create: if isAuth() && request.auth.uid == userId;

      // SubCollections under Users
      match /{allChildren=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // BUSINESSES COLLECTION
    // ═══════════════════════════════════════════════════════════════════

    // /businesses/{businessId} - Business listings
    match /businesses/{businessId} {
      // Anyone can read business listings
      allow read: if true;

      // Authenticated users can create new businesses
      // The business document MUST have an 'ownerId' field set to the creating user's UID
      allow create: if isAuth() &&
                      request.resource.data.ownerId == userId() &&
                      request.resource.data.keys().hasAll(['name', 'ownerId', 'category']);

      // Only the business owner can update their business
      allow update: if isBusinessOwner(resource.data.ownerId);

      // Only the business owner can delete their business
      allow delete: if isBusinessOwner(resource.data.ownerId);

      // ─────────────────────────────────────────────────────────────────
      // Reviews SubCollection
      // ─────────────────────────────────────────────────────────────────
      match /reviews/{reviewId} {
        // Anyone can read reviews
        allow read: if true;

        // Authenticated users can create reviews
        // Reviews MUST have userId field matching the creating user
        allow create: if isAuth() &&
                        request.resource.data.userId == userId() &&
                        request.resource.data.keys().hasAll(['userId', 'rating', 'text']);

        // Users can only update their own reviews
        allow update: if isAuth() && resource.data.userId == userId();

        // Users can only delete their own reviews
        allow delete: if isAuth() && resource.data.userId == userId();
      }

      // ─────────────────────────────────────────────────────────────────
      // Images SubCollection
      // ─────────────────────────────────────────────────────────────────
      match /images/{imageId} {
        // Anyone can read images
        allow read: if true;

        // Only business owner can create images
        allow create: if isBusinessOwner(get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId);

        // Only business owner can delete images
        allow delete: if isBusinessOwner(get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // CHATS COLLECTION (for messaging feature)
    // ═══════════════════════════════════════════════════════════════════

    // /chats/{chatId} - Chat conversations
    match /chats/{chatId} {
      // Users involved in the chat can read it
      allow read: if isAuth() && request.auth.uid in resource.data.participantIds;

      // Authenticated users can create new chats
      allow create: if isAuth() &&
                      request.auth.uid in request.resource.data.participantIds;

      // ─────────────────────────────────────────────────────────────────
      // Messages SubCollection
      // ─────────────────────────────────────────────────────────────────
      match /messages/{messageId} {
        // Users in the chat can read messages
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;

        // Users can only send messages to chats they're part of
        allow create: if isAuth() &&
                        request.resource.data.senderId == userId() &&
                        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;

        // Users can only delete their own messages
        allow delete: if isAuth() && resource.data.senderId == userId();
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // NOTIFICATIONS COLLECTION
    // ═══════════════════════════════════════════════════════════════════

    // /notifications/{notificationId} - User notifications
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isOwner(resource.data.userId);

      // System (backend) can create notifications
      // Client restrictions: only to own user ID
      allow create: if isAuth() && request.resource.data.userId == userId();

      // Users can update (mark as read) their own notifications
      allow update: if isOwner(resource.data.userId);

      // Users can delete their own notifications
      allow delete: if isOwner(resource.data.userId);
    }

    // ═══════════════════════════════════════════════════════════════════
    // OTHER COLLECTIONS
    // ═══════════════════════════════════════════════════════════════════

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
